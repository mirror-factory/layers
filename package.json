{
  "name": "audio-layer",
  "version": "0.0.9",
  "private": true,
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "typecheck": "next typegen && tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "next lint",
    "eval": "tsx evals/run-evals.ts",
    "eval:live": "tsx evals/live-eval.ts",
    "generate:fixtures": "tsx scripts/generate-test-fixtures.ts lib/ai/tool-meta.ts --output=tests/generated/registry-fixtures.ts",
    "generate:registry": "tsx scripts/generate-from-registry.ts lib/ai/tool-meta.ts",
    "validate:registry": "tsx scripts/validate-registry-sync.ts lib/ai/tool-meta.ts",
    "gates": "tsx scripts/gates.ts",
    "prepare": "husky",
    "compliance": "tsx scripts/check-compliance.ts",
    "docs:manifest": "tsx scripts/docs-generate-manifest.ts",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "test:visual": "playwright test tests/e2e/visual-regression.spec.ts",
    "test:mobile": "playwright test tests/e2e/mobile.spec.ts",
    "test:load": "tsx scripts/load-test.ts",
    "test:ai:local": "tsx scripts/test-ai-local.ts",
    "test:all": "pnpm typecheck && pnpm test && pnpm test:e2e",
    "detect:drift": "tsx scripts/detect-drift.ts",
    "rubrics:generate": "tsx scripts/generate-tool-rubrics.ts",
    "rubrics:run": "tsx scripts/run-rubrics.ts",
    "research:bootstrap": "tsx scripts/research-bootstrap.ts",
    "research:refresh": "tsx scripts/research-refresh.ts",
    "research:agents-md": "tsx scripts/research-generate-agents-md.ts"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.103",
    "@ai-sdk/react": "^3.0.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/status-bar": "^8.0.2",
    "@langfuse/otel": "^4.6.1",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.47.0",
    "ai": "^6.0.167",
    "assemblyai": "^4.15.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.0",
    "stripe": "^22.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "^0.0.15",
    "@capacitor/cli": "^8.3.1",
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^15.3.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.1.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
