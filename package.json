{
  "name": "audio-layer",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "electron:dev": "NODE_ENV=development electron electron/main.js",
    "electron:build": "electron-builder --config electron-builder.yml",
    "electron:pack": "electron-builder --dir --config electron-builder.yml",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:eval": "vitest --config vitest.eval.config.ts run",
    "test:all": "pnpm typecheck && vitest run --reporter=json --outputFile=test-results/unit.json && pnpm test:eval && pnpm compliance && node scripts/ingest-run-results.mjs",
    "compliance": "tsx scripts/check-compliance.ts",
    "test:live": "vitest run tests/integration",
    "test:api": "start-server-and-test \"pnpm build && pnpm start\" http://localhost:3000/api/health \"vitest run tests/api\"",
    "test:visual": "playwright test tests/e2e/visual-regression.spec.ts",
    "test:visual:mobile": "playwright test --project=mobile-light --project=mobile-dark",
    "test:visual:desktop": "playwright test --project=desktop-light --project=desktop-dark",
    "test:light": "playwright test --project=mobile-light --project=desktop-light",
    "test:dark": "playwright test --project=mobile-dark --project=desktop-dark",
    "test:a11y": "vitest run --include \"**/*.a11y.test.ts*\"",
    "ingest:runs": "node scripts/ingest-run-results.mjs",
    "check:deprecations": "tsx scripts/check-deprecations.ts",
    "secrets:check": "tsx scripts/generate-secrets-md.ts",
    "dev-kit:doctor": "npx ai-dev-kit doctor",
    "dev-kit:audit": "npx ai-dev-kit audit",
    "dev-kit:tool:add": "npx ai-dev-kit tool add",
    "dev-kit:tool:validate": "npx ai-dev-kit tool validate",
    "postinstall": "node scripts/doctor-first-run.mjs || true",
    "dev-kit:doctor:strict": "npx ai-dev-kit doctor --strict"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.104",
    "@base-ui/react": "^1.4.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/status-bar": "^8.0.2",
    "@langfuse/otel": "^5.1.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/sdk-node": "^0.205.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-pdf/renderer": "^4.5.1",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "ai": "^6.0.168",
    "assemblyai": "^4.30.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "langfuse": "^3.38.20",
    "lucide-react": "^1.8.0",
    "next": "15.5.15",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.0",
    "shadcn": "^4.3.1",
    "stripe": "^22.0.2",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "^0.0.15",
    "@ai-sdk/react": "^3.0.170",
    "@capacitor/cli": "^8.3.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "ts-morph": "^28.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
