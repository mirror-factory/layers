# ═══════════════════════════════════════════════════════════════
# audio-layer — Environment Variables
# ═══════════════════════════════════════════════════════════════

# ── Vercel AI Gateway (primary routing for LLM summaries) ─────
# Required for AI SDK v6 gateway mode
AI_GATEWAY_API_KEY=
DEFAULT_MODEL=anthropic/claude-sonnet-4-6
TEST_MODEL=google/gemini-3.1-flash-lite

# ── Direct provider keys (fallback / when gateway=false) ──────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# ── AssemblyAI (transcription — direct, NOT via Gateway) ──────
# Streaming (live meeting captions): u3-rt-pro  — $0.45/hr
# Pre-recorded (post-meeting):        best      — $0.21/hr (Universal-3 Pro)
# See product reference doc §5 for full API surface.
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_STREAMING_MODEL=u3-rt-pro
ASSEMBLYAI_BATCH_MODEL=best
ASSEMBLYAI_WEBHOOK_SECRET=

# ── Langfuse (observability) ──────────────────────────────────
# Sign up at https://cloud.langfuse.com (free tier: 50K observations/month)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Supabase (storage + auth, pgvector for semantic search) ───
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Integrations ──────────────────────────────────────────────
LINEAR_API_KEY=
FIRECRAWL_API_KEY=
SLACK_WEBHOOK_URL=

# ── Deployment ────────────────────────────────────────────────
VERCEL_TOKEN=

# ── Application ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=
