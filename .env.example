# AI_STARTER_ENV_START
# AI Starter Kit generated environment contract.
# Do not put real secrets in this committed file.
# Put secrets in .env.local or pull them with `vercel env pull .env.local --yes`.

DEFAULT_MODEL=anthropic/claude-sonnet-4.6
TEST_MODEL=google/gemini-3.1-flash-lite
EVAL_MODEL=google/gemini-3.1-flash-lite
AI_GATEWAY_API_KEY=
VERCEL_OIDC_TOKEN=

# AI_STARTER_ENV_END

# ── PROD-371: post-launch monitoring + watchlist alerts ──
# Slack incoming webhook used by /api/internal/alerts and the watchlist cron
# (`/api/cron/watchlist-tick`). Unset = log-only fallback so thresholds can
# be dry-run without burning a real channel.
ALERT_WEBHOOK_URL=
# Shared secret gating /api/internal/* and the watchlist cron when CRON_SECRET
# isn't set. Required in production.
INTERNAL_ADMIN_TOKEN=
# Vercel injects this automatically into cron-triggered requests. Set the
# same value in env so the route accepts it. See vercel.json.
CRON_SECRET=
