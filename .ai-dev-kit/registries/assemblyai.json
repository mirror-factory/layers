    { "id": "universal-2", "label": "Universal-2", "use_for": "99 language support", "price_per_hour_usd": 0.15, "deprecated": false },
    { "id": "nano", "label": "Nano", "use_for": "Fastest, cheapest", "price_per_hour_usd": 0.12, "deprecated": false }
  ],
  "streaming_models": [
